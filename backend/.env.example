# ─────────────────────────────────────────────
# ChefOs Backend — Environment Configuration
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# Server
NODE_ENV=production
PORT=5000

# MongoDB — Use docker-compose value if using Docker
MONGODB_URI=mongodb://localhost:27017/ritam_bharat_pos

# ─── JWT — MUST change these in production ───
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_REFRESH_SECRET=change-this-to-another-random-64-char-string
JWT_EXPIRE=1h
JWT_REFRESH_EXPIRE=7d

# CORS — Comma-separated origins allowed (no trailing slash)
# Production example: https://ritambharat.vercel.app,https://ritambharat.com
ALLOWED_ORIGINS=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# ─── WhatsApp Cloud API ──────────────────────
WHATSAPP_VERIFY_TOKEN=menusphere_whatsapp_token
META_ACCESS_TOKEN=
META_PHONE_ID=
META_WABA_ID=

# ─── Redis (optional, for caching) ──────────
REDIS_URL=

# ─── Cloudinary (optional, for image upload) ─
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Web Push (VAPID) ──────────────────────
# Generate keys: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ─── Seed Credentials (first-time setup) ────
ADMIN_EMAIL=owner@foodcourt.com
ADMIN_PASSWORD=Test@123!
ADMIN_NAME=Restaurant Owner
RESTAURANT_NAME=Food Court
STAFF_CASHIER_PIN=1234
STAFF_CASHIER_NAME=Cashier One
STAFF_WAITER_PIN=5678
STAFF_WAITER_NAME=Waiter One
STAFF_CHEF_PIN=0000
STAFF_CHEF_NAME=Chef One
